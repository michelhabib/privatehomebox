{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Gateway Start",
        "type": "debugpy",
        "request": "launch",
        "python": "${workspaceFolder}\\phbserver\\.venv\\Scripts\\python.exe",
        "module": "phbgateway.main",
        "args": ["start", "--foreground"],
        "cwd": "${workspaceFolder}\\phbserver",
        "env": {
          "PYTHONPATH": "${workspaceFolder}\\phbserver\\gateway\\src;${workspaceFolder}\\phbserver\\phb-channel-sdk\\src"
        },
        "console": "integratedTerminal",
        "justMyCode": false
      },
      {
        "name": "Server Start",
        "type": "debugpy",
        "request": "launch",
        "python": "${workspaceFolder}\\phbserver\\.venv\\Scripts\\python.exe",
        "program": "${workspaceFolder}\\phbserver\\.venv\\Scripts\\phbcli.exe",
        "args": ["start", "--foreground", "--admin"],
        "cwd": "${workspaceFolder}\\phbserver",
        "env": {
          "PYTHONPATH": "${workspaceFolder}\\phbserver\\phbcli\\src;${workspaceFolder}\\phbserver\\phb-channel-sdk\\src"
        },
        "console": "integratedTerminal",
        "justMyCode": false
      },
      {
        "name": "Flutter Web Start",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")/device_apps\" && fvm flutter run -d chrome --web-port 63000"
      },
      {
        "name": "Flutter Android Start",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")/device_apps\" && fvm flutter run -d android"
      },
      {
        "name": "Mint Docs Start",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")/mintdocs\" && mint dev"
      },
      {
        "name": "Diagram Generator Start",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")\" && uv run python diagram-gen/generate.py"
      }
    ],
    "compounds": [
      {
        "name": "Debug Gateway + phbcli + Flutter device_apps",
        "configurations": [
          "Gateway Start",
          "Server Start",
          "Flutter Web Start"
        ]
      }
    ]
  }
  
