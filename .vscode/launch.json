{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Debug phbgateway",
        "type": "debugpy",
        "request": "launch",
        "python": "${workspaceFolder}\\phbserver\\.venv\\Scripts\\python.exe",
        "module": "phbgateway.main",
        "args": ["-f"],
        "cwd": "${workspaceFolder}\\phbserver",
        "env": {
          "PYTHONPATH": "${workspaceFolder}\\phbserver\\gateway\\src;${workspaceFolder}\\phbserver\\phb-channel-sdk\\src"
        },
        "console": "integratedTerminal",
        "justMyCode": false
      },
      {
        "name": "Debug phbcli start -f",
        "type": "debugpy",
        "request": "launch",
        "python": "${workspaceFolder}\\phbserver\\.venv\\Scripts\\python.exe",
        "program": "${workspaceFolder}\\phbserver\\.venv\\Scripts\\phbcli.exe",
        "args": ["start", "--foreground"],
        "cwd": "${workspaceFolder}\\phbserver",
        "env": {
          "PYTHONPATH": "${workspaceFolder}\\phbserver\\phbcli\\src;${workspaceFolder}\\phbserver\\phb-channel-sdk\\src"
        },
        "console": "integratedTerminal",
        "justMyCode": false
      },
      {
        "name": "Terminal Flutter device_apps (web)",
        "type": "node-terminal",
        "request": "launch",
        "command": "cmd /k \"cd /d ${workspaceFolder}\\device_apps && fvm flutter run -d chrome --web-port 63000\""
      },
      {
        "name": "Terminal Flutter device_apps (android)",
        "type": "node-terminal",
        "request": "launch",
        "command": "cmd /k \"cd /d ${workspaceFolder}\\device_apps && fvm flutter run -d android\""
      },
      {
        "name": "Terminal mint dev",
        "type": "node-terminal",
        "request": "launch",
        "command": "cmd /k \"cd /d ${workspaceFolder}\\mintdocs && mint dev\""
      },
      {
        "name": "Terminal diagram-gen",
        "type": "node-terminal",
        "request": "launch",
        "command": "cmd /k \"cd /d ${workspaceFolder} && uv run python diagram-gen/generate.py\""
      }
    ],
    "compounds": [
      {
        "name": "Debug Gateway + phbcli + Flutter device_apps",
        "configurations": [
          "Debug phbgateway",
          "Debug phbcli start -f",
          "Terminal Flutter device_apps (web)"
        ]
      }
    ]
  }
  